    "import mlflow\n",
    "\n",
    "exp = mlflow.get_experiment_by_name(\"0\")\n",
    "runs = mlflow.search_runs(\n",
    "    experiment_ids=[exp.experiment_id],\n",
    "    order_by=[\"start_time DESC\"],\n",
    "    max_results=1,\n",
    ")\n",
    "\n",
    "run_id = runs.iloc[0][\"run_id\"]\n",
    "print(run_id)"
   ]
